<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="16dp"
    app:strokeColor="@color/card_border"
    app:strokeWidth="1dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Favorite Button (Top Right) -->
        <ImageView
            android:id="@+id/btn_favorite"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Favorite Toggle"
            android:padding="6dp"
            android:elevation="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Logo Container (Centered) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/search_background"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/img_logo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_slideshow"
                    android:contentDescription="Channel Logo" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Channel Name (Centered) -->
            <TextView
                android:id="@+id/txt_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Channel Name"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center" />

            <!-- Group Indicator (Centered Badge) -->
            <TextView
                android:id="@+id/txt_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@color/search_background"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="MOVIES"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Now Playing (Compact representation) -->
            <LinearLayout
                android:id="@+id/now_playing_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:gravity="center_horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txt_now_playing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Now Playing"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:gravity="center" />

                <!-- Simple progress indicator -->
                <ProgressBar
                    android:id="@+id/epg_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="3dp"
                    android:progressDrawable="@android:drawable/progress_horizontal"
                    android:indeterminate="false" />
            </LinearLayout>

            <!-- Fallback Tag Container (Invisible in Grid if we want to save space, but kept for ID compatibility) -->
            <LinearLayout
                android:id="@+id/fallback_tag_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txt_default_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STREAM"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Next program text (Invisible in grid to keep clean, but kept for ID compatibility) -->
            <TextView
                android:id="@+id/txt_next_playing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next Program"
                android:visibility="gone" />

        </LinearLayout>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
